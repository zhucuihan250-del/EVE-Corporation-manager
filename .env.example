# Frontend service (@workspace/pap-tracker)
# Frontend build base path.
BASE_PATH=/

# Public api-server origin used by the standalone frontend service. Do not include a trailing slash.
# Leave unset when the frontend is served by api-server in same-origin production.
VITE_API_URL=https://your-api-server.up.railway.app

# Optional local Vite proxy target when VITE_API_URL is not set.
API_PORT=3000
API_URL=http://localhost:3000

# Backend service (@workspace/api-server)
# Railway sets PORT automatically. Use this only for local runs.
PORT=3000

# PostgreSQL connection string. Production URLs should verify TLS.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=verify-full

# Use a long, random value in production.
SESSION_SECRET=replace-with-a-long-random-secret

# EVE developer application credentials.
EVE_CLIENT_ID=replace-with-eve-client-id
EVE_CLIENT_SECRET=replace-with-eve-client-secret

# Public app origin. For same-origin production, use the api-server public domain.
# The backend redirects EVE SSO users here after callback.
FRONTEND_URL=https://your-api-server.up.railway.app

# Comma-separated browser origins allowed to call the API with credentials.
# Defaults to FRONTEND_URL when omitted.
CORS_ORIGIN=https://your-api-server.up.railway.app

# Optional runtime configuration.
LOG_LEVEL=info

# Optional identifier sent with ESI and zKillboard BR requests.
EVE_ESI_USER_AGENT=EVE-PAP-Tracker/1.0 (admin@example.com)
